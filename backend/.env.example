# PostgreSQL (VPS própria)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@localhost:5432/app_financeiro

# Supabase Auth (apenas o serviço de autenticação — banco é o PostgreSQL acima)
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_ANON_KEY=
# Supabase dashboard → Project Settings → Data API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Pluggy (https://dashboard.pluggy.ai)
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# OpenRouter (free tier — https://openrouter.ai)
OPENROUTER_KEY=

# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
